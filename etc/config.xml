<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <payment>
            <omnissolutio_gateway>
                <active>0</active>
                <title>Omnis Solutio</title>
                <model>OmnisSolutioPaymentGatewayFacade</model>
                <environment>sandbox</environment>
                <payment_action>authorize_capture</payment_action>
                <order_status>processing</order_status>
                <allowspecific>0</allowspecific>
                <debug>0</debug>

                <!-- Platform-level public defaults — overridable per store in admin. -->
                <tenant_id>TNT-00000213</tenant_id>
                <evervault_team_id>team_83699f3104e8</evervault_team_id>
                <evervault_app_id>app_0597d16048a0</evervault_app_id>
                <!--
                    pg_public_key default — bare base64 body (PEM headers added at runtime).
                    Replace with your own key in Stores > Configuration if it changes.
                -->
                <pg_public_key></pg_public_key>
                <!-- base_url: leave empty to use https://api.solutio.com -->
                <base_url></base_url>

                <!-- Gateway capability flags -->
                <is_gateway>1</is_gateway>
                <can_use_checkout>1</can_use_checkout>
                <can_use_internal>0</can_use_internal>
                <!--
                    can_initialize=1 routes placeOrder through the initialize command,
                    landing the order in pending_payment BEFORE the iframe opens.
                    This is required for the order-first flow (Phase D, step 2).
                -->
                <can_initialize>1</can_initialize>
                <can_authorize>1</can_authorize>
                <can_capture>1</can_capture>
                <can_refund>1</can_refund>
                <can_refund_partial_per_invoice>1</can_refund_partial_per_invoice>
                <can_void>1</can_void>
            </omnissolutio_gateway>
        </payment>
    </default>
</config>
