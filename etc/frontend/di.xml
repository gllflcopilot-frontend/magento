<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!--
    =========================================================
    Phase D — expose public checkout config to window.checkoutConfig.
    Registered in the frontend area only so it never runs in admin.
    =========================================================
    -->
    <type name="Magento\Checkout\Model\CompositeConfigProvider">
        <arguments>
            <argument name="configProviders" xsi:type="array">
                <item name="omnissolutio_config_provider" xsi:type="object">
                    OmnisSolutio\PaymentGateway\Model\Ui\ConfigProvider
                </item>
            </argument>
        </arguments>
    </type>

</config>
