<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="payment">
            <group id="omnissolutio_gateway" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Omnis Solutio Payment Gateway</label>
                <comment><![CDATA[Add your webhook endpoint to the Omnis Solutio dashboard: <code>https://yourstore.com/omnissolutio/webhook</code>]]></comment>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                </field>
                <field id="environment" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Environment</label>
                    <source_model>OmnisSolutio\PaymentGateway\Model\Config\Source\Environment</source_model>
                </field>
                <field id="key_secret" translate="label comment" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Secret (Key Secret)</label>
                    <comment>Your HMAC signing secret (VITE_API_SECRET). Used server-side to sign every payin request — never sent to the browser.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="tenant_id" translate="label comment" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Tenant ID</label>
                    <comment>Value for the X-TenantID request header (e.g. TNT-00000213). Provided by Omnis Solutio.</comment>
                </field>
                <field id="pg_public_key" translate="label comment" type="textarea" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>PG Public Key</label>
                    <comment><![CDATA[RSA public key used to wrap the per-request AES key. Paste the full PEM block <em>or</em> just the base64 body — either form is accepted.]]></comment>
                </field>
                <field id="webhook_secret" translate="label comment" type="obscure" sortOrder="65" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Webhook Secret</label>
                    <comment>Used server-side to verify the HMAC signature of incoming webhook events (Phase E).</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="evervault_team_id" translate="label comment" type="text" sortOrder="67" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Evervault Team ID</label>
                    <comment>Public client-safe value forwarded to the checkout iframe (e.g. team_83699f3104e8).</comment>
                </field>
                <field id="evervault_app_id" translate="label comment" type="text" sortOrder="68" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Evervault App ID</label>
                    <comment>Public client-safe value forwarded to the checkout iframe (e.g. app_0597d16048a0).</comment>
                </field>
                <field id="base_url" translate="label comment" type="text" sortOrder="69" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Base URL (Override)</label>
                    <comment>Leave blank to use https://api.solutio.com. Set only if Omnis Solutio provides a custom endpoint.</comment>
                </field>
                <field id="payment_action" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Payment Action</label>
                    <source_model>OmnisSolutio\PaymentGateway\Model\Config\Source\PaymentAction</source_model>
                </field>
                <field id="order_status" translate="label" type="select" sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Order Status After Payment</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status\NewStatus</source_model>
                </field>
                <field id="allowspecific" translate="label" type="allowspecific" sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Payment from Applicable Countries</label>
                    <source_model>Magento\Payment\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Payment from Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
                <field id="min_order_total" translate="label" type="text" sortOrder="110" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Minimum Order Total</label>
                </field>
                <field id="max_order_total" translate="label" type="text" sortOrder="120" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Maximum Order Total</label>
                </field>
                <field id="debug" translate="label" type="select" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Debug Mode</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="140" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sort Order</label>
                </field>
            </group>
        </section>
    </system>
</config>
